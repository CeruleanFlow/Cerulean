CERULEAN_HTTP_ADDR=:8080
CERULEAN_CORS_ORIGINS=http://localhost:5173

# Development database. json is dependency-free and persistent.
# Later we can replace it with PostgreSQL/SQLite migrations.
CERULEAN_DB_DRIVER=mysql
CERULEAN_MYSQL_DSN=cerulean:cerulean@tcp(127.0.0.1:3306)/cerulean?charset=utf8mb4&parseTime=True&loc=Local
CERULEAN_DB_PATH=.var/cerulean.json

# Object storage. local is the dependency-free adapter for this checkpoint.
# MinIO is the target object storage adapter for the next step.
CERULEAN_STORAGE_DRIVER=local
CERULEAN_LOCAL_STORAGE_DIR=.var/objects
CERULEAN_MINIO_ENDPOINT=localhost:9000
CERULEAN_MINIO_ACCESS_KEY=minioadmin
CERULEAN_MINIO_SECRET_KEY=minioadmin
CERULEAN_MINIO_BUCKET=cerulean-papers
CERULEAN_MINIO_USE_SSL=false

# Search backends.
# local: dependency-free keyword search over stored chunks.
# hybrid: placeholder Elasticsearch + Amaranth backend, kept for the future integration.
CERULEAN_SEARCH_DRIVER=local
CERULEAN_ELASTIC_URL=http://localhost:9200
CERULEAN_ELASTIC_INDEX=cerulean_chunks
CERULEAN_AMARANTH_URL=http://localhost:9090
CERULEAN_AMARANTH_COLLECTION=papers

# Planned model providers.
CERULEAN_LLM_BASE_URL=
CERULEAN_LLM_MODEL=deepseek-chat
CERULEAN_EMBEDDING_PROVIDER=astraflow
CERULEAN_RERANK_PROVIDER=astraflow
CERULEAN_OCR_PROVIDER=paddleocr
